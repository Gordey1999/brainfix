        if (key == 107) word = 'ноутбук';
        if (key == 108) word = 'лазер';
        if (key == 109) word = 'тостер';
        if (key == 110) word = 'радиатор';
        if (key == 111) word = 'фотоаппарат';
        if (key == 112) word = 'марсоход';
        if (key == 113) word = 'мультиварка';
        if (key == 114) word = 'испаритель';
        if (key == 115) word = 'принтер';
        if (key == 116) word = 'телефон';
        if (key == 117) word = 'акустика';
        if (key == 118) word = 'вагон';
        if (key == 119) word = 'приставка';
        if (key == 120) word = 'телеграф';
        if (key == 121) word = 'хронометр';
        if (key == 122) word = 'катамаран';
        if (key == 123) word = 'сервер';
        if (key == 124) word = 'трейлер';
        if (key == 125) word = 'проектор';
        if (key == 126) word = 'факс';
        if (key == 127) word = 'процессор';
    }


    # Заполняем wordPrint
    for (byte i = 0; i < sizeof word; i++)
    {
        if (word[i]) wordPrint[i] = '_';
    }

    roundCount++;

    # Цикл раунда
    bool round = true;
    while (round)
    {
        #################################
        #           ОТРИСОВКА           #
        #################################

        out '\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n';

        if (lives == 7) out '             ';
        else            out '_______      ';
        if (topic == 0)      out '--------   ЕДА   --------\n';
        else if (topic == 1) out '------   ЖИВОТНЫЕ   -----\n';
        else if (topic == 2) out '-----   ПРОФЕССИИ   -----\n';
        else if (topic == 3) out '------   ТЕХНИКА   ------\n';

        if (lives == 7) out '             \n';
        else            out '|     |      \n';

        if (lives == 7) out '    ';
        else            out '|   ';
        if (lives > 5)  out '    ';
        else            out ' -V-';
        out '     Слово:\n';

        if (lives == 7) out '    ';
        else            out '|   ';
        if (lives > 5)  out '         ';
        else if (lives) out '(o o)    ';
        else            out '(x x)    ';
        for (byte i = 0; i < sizeof wordPrint; i++)
        {
            out wordPrint[i], ' ';
        }
        out eol;

        if (lives == 7) out '    ';
        else            out '|   ';
        if (lives > 5)  out '         ';
        else            out ' -^-     ';
        out eol;

        if (lives == 7) out '    ';
        else            out '|   ';
        if (lives > 3)  out '  ';
        else            out ' /';
        if (lives > 4)  out ' ';
        else            out '|';
        if (lives > 2)  out '      ';
        else            out '\     ';
        if (lives == 0) out 'Ты проиграл!\n';
        else if (won)   out 'Ты победил!\n';
        else            out 'Доступные буквы:\n';

        if (lives == 7) out '    ';
        else            out '|   ';
        if (lives > 3)  out '  ';
        else            out '/ ';
        if (lives > 4)  out ' ';
        else            out '|';
        if (lives > 2)  out '      ';
        else            out ' \    ';
        if (lives && !won)
        {
            for (byte i = 0; i < 11; i++)
            {
                char letter = 'А' + i;
                if (letters[i]) out letter, ' ';
                else            out '  ';
            }
        }
        out eol;

        if (lives == 7) out '    ';
        else            out '|   ';
        if (lives > 4)  out '         ';
        else            out '  |      ';
        if (lives && !won)
        {
            for (byte i = 11; i < 22; i++)
            {
                char letter = 'А' + i;
                if (letters[i]) out letter, ' ';
                else            out '  ';
            }
        }
        out eol;

        if (lives == 7) out '    ';
        else            out '|   ';
        if (lives > 1)  out '   ';
        else            out ' / ';
        if (lives)      out '      ';
        else            out '\     ';
        if (lives && !won)
        {
            for (byte i = 22; i < 32; i++)
            {
                char letter = 'А' + i;
                if (letters[i]) out letter, ' ';
                else            out '  ';
            }
        }
        else
        {
            out 'Отгадано слов: ', wonCount, ' из ', roundCount;
        }
        out eol;

        if (lives == 7) out '    ';
        else            out '|   ';
        if (lives > 1)  out '   ';
        else            out '/  ';
        if (lives)      out '  ';
        else            out ' \';
        out eol;

        if (lives == 7) out '             ';
        else            out '|            ';
        if (lives == 0 || won) out 'Enter - продолжить';
        else if (status == 0)  out 'Введи букву и нажми Enter';
        else if (status == 1)  out 'Введена не буква!';
        else if (status == 2)  out 'Неверная раскладка!';
        else if (status == 3)  out 'Буква ', letter, ' уже была!';
        else if (status == 4)  out 'Буквы ', letter, ' в слове нет!';
        else                   out 'Буква ', letter, ' в слове есть!';

        out '\n\n> ';


        #################################
        #        ОБРАБОТКА ВВОДА        #
        #################################
        char input;
        in input;
        letter = input;
        while (input != '\n')
        {
            in input;
        }

        if (letter >= 'а' && letter <= 'я') letter -= ('а' - 'А');
        if (letter >= 'a' && letter <= 'z') letter -= ('a' - 'A');

        if (won || lives == 0)
        {
            # При завершении раунда выходим из цикла
            round = false;
            status = 0;
        }
        else if (letter >= 'А' && letter <= 'Я')
        {
            # Если буквы еще не было
            if (letters[letter - 'А'])
            {
                bool found = false;

                # Проверяем слово
                for (byte i = 0; i < sizeof word; i++)
                {
                    if (letter + 32 == word[i])
                    {
                        found = true;
                        wordPrint[i] = letter;
                    }
                }

                if (found)
                {
                    status = 5;
                }
                else
                {
                    status = 4;
                    lives--;
                }

                letters[letter - 'А'] = false;

                # Обновляем сид, чтобы слова не повторялись
                seed = 137 * seed + 1;
            }
            else
            {
                status = 3; # уже была
            }
        }
        else if (letter >= 'A' && letter <= 'Z')
        {
            status = 2; # неверная раскладка
        }
        else
        {
            status = 1; # введена не буква
        }


        #################################
        #          КОНЕЦ ИГРЫ           #
        #################################

        # Если попытки закончились, открываем слово
        if (lives == 0)
        {
            for (byte i = 0; i < sizeof word; i++)
            {
                if (word[i])
                {
                    wordPrint[i] = word[i] - 32;
                }
            }
        }
        # Если введена верная буква, отгадано ли все слово
        else if (status == 5)
        {
            won = true;
            for (byte i = 0; i < sizeof word; i++)
            {
                if (word[i] && wordPrint[i] == '_')
                {
                    won = false;
                }
            }
            if (won)
            {
                wonCount++;
            }
        }

    }
}