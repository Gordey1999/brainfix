    # Статусы ввода
    # 0 - Начало раунда
    # 1 - Введена не буква
    # 2 - Неверная раскладка
    # 3 - Буква уже вводилась ранее
    # 4 - Такой буквы в слове нет
    # 5 - Буква есть в слове
    byte status = 0;

