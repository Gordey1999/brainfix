# @title: Исходный код

# Это исходный код Виселицы, написанный на BrainFix.
# И его можно редактировать.
# Чтобы собрать код в Brainfuck, используй кнопки BUILD или MIN.
# Но процесс сборки не быстрый.


# Темы:
# 0 - Еда
# 1 - Животные
# 2 - Профессии
# 3 - Техника
byte seed, topic;
bool play = true;
bool randomTopic = false;


out '\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n';
out 'Для старта нам нужен сид\n';
out 'для генерации случайных чисел.\n';
out '\n';
out 'Введи любое слово или число\n';
out 'и нажми Enter.\n';
out '\n> ';
in seed;




while (topic < '1' || topic > '5')
{
    out '\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n';
    out '------------   ВИСЕЛИЦА   ------------\n';
    out '_______                       by Gordy\n';
    out '|     |    Выбери категорию:\n';
    out '|     |\n';
    out '|    / \   1. Еда\n';
    out '|    \_/   2. Животные\n';
    out '|          3. Профессии\n';
    out '|          4. Техника\n';
    out '|          5. Случайная\n';
    out '|\n';
    out '|  Введи номер категории и нажми Enter\n';
    out '\n> ';

    char input;
    in input;
    topic = input;
    while (input != '\n')
    {
        in input;
    }
}

topic -= '1';
if (topic == 4) randomTopic = true;


byte wonCount = 0, roundCount = 0;


