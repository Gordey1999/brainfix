    "code": "# @title: Исходный код\n\n# @buffered_input: false\n# @console_color: #5affe4\n\n# Это исходный код игры НИМ. Его можно редактировать.\n# Чтобы скомпилировать код в brainfuck, нажми BUILD или MIN\n\n\nout '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\nout '|\\  |  *  |\\ /|\\n';\nout '| \\ |  |  | v |\\n';\nout '|  \\|  |  |   |     BF ENGINE by Gordy\\n\\n\\n';\n\nout 'ПРАВИЛА ИГРЫ:\\n';\nout '* Игроки по очереди тянут спички из четырех кучек.\\n';\nout '* За ход игрок тянет любое число спичек из любой кучки.\\n';\nout '* Кто вытянет последнюю - проиграет.\\n\\n\\n';\nout 'Cложность ИИ: БОЛЬ.                  [ SPACE - НАЧАТЬ ]\\n\\n> ';\n\nin 'dummy';\n\n\n\nbool play = true;\nbool aiFirst = false;\nbyte win = 0, loss = 0;\n\nwhile (play)\n{\n    byte sticks[] = [1, 3, 5, 7];\n    byte selRow = 0, selCount = 1;\n    byte moveMade = false;\n    bool gaveUp = false;\n\n    # Значения move:\n    # 0 - Ход игрока\n    # 1 - Применение хода игрока\n    # 2 - Показ хода ИИ\n    # 3 - Победа!\n    # 4 - Поражение\n    byte move = 0;\n    bool roundCycle = true, isFirst = true;\n\n    if (aiFirst)\n    {\n        move = 1;\n        selCount = 0;\n    }\n    aiFirst = !aiFirst;\n    \n    while (roundCycle)\n    {   \n        #################################\n        #           ОТРИСОВКА           #\n        #################################\n        out '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\n    \n        for (byte row = 0; row < sizeof sticks; row++)\n        {\n            for (byte i = 0; i < 7; i++)\n            {\n                if (i < sticks[row]) out '*  ';\n                else                 out '   ';\n            }\n\n            if (row == 0)\n            {\n                if (move == 3)       out ' ПОБЕДА!';\n                else if (move == 4)  out ' П О Р А Ж Е Н И Е';\n                else\n                {\n                    #####   СЧЕТ   #####\n                    out ' ТЫ  ';\n                    if (win < 100)  out ' ';\n                    if (win < 10)   out ' ';\n                    out win, ' : ', loss;\n                    if (loss < 100) out ' ';\n                    if (loss < 10)  out ' ';\n                    out '  ИИ';\n                }\n            }\n            else if (row == 1)\n            {\n                #####   СТАТУС ХОДА   #####\n                if      (gaveUp)               out ' Ты сдался';\n                else if (move == 3)            out ' ИИ вытянул последнюю';\n                else if (move == 4)            out ' Ты вытянул последнюю';\n                else if (isFirst && move == 0) out ' Ты ходишь первым';\n                else if (isFirst)              out ' Первым ходит ИИ';\n                else if (move == 0)            out ' Твой ход';\n                else if (move == 1)            out ' Теперь ходит ИИ';\n                else                           out ' Ход ИИ';\n            }\n            else if (row == 3 && move == 0)\n            {\n                out ' SPACE - Выбор';\n            }\n            \n            out '\\n';\n\n            for (byte i = 0; i < 7; i++)\n            {\n                if (i < sticks[row]) out '|  ';\n                else                 out '   ';\n            }\n\n            \n            if (row == 3)\n            {\n                if (move == 0) out ' Q     - Сдаться';\n                else           out ' SPACE - Продолжить';\n            }\n            \n            out '\\n';\n\n            #   СЕЛЕКТ   #\n            if (selRow == row)\n            {\n                byte leftCount = sticks[row] - selCount;\n    \n                for (byte j = 0; j < leftCount; j++)   out '   ';\n                for (byte j = 0; j < selCount; j++)\n                {\n                    if (move == 0) out '^  ';\n                    else           out '~  '; # · / ~ ‘\n                }\n                for (byte j = sticks[row]; j < 7; j++) out '   ';\n            }\n            else\n            {\n                out '                     ';\n            }\n\n            if (row == 2 && move == 0)\n            {\n                out ' WASD  - Перемещение';\n            }\n            \n            out '\\n';\n        }\n        out '> ';\n\n\n\n        char input;\n        in input;\n\n        if (move != 0)\n        {\n            while (input != ' ') in input;\n        }\n\n        #################################\n        #           ХОД ИГРОКА          #\n        #################################\n        if (move == 0)\n        {\n            bool again = true;\n            do\n            {\n                if (input == 'w' || input == 'ц')\n                {\n                    byte newRow = selRow;\n\n                    for (byte i = 0; i < selRow; i++)\n                    {\n                        if (sticks[i]) newRow = i;\n                    }\n\n                    if (newRow !== selRow)\n                    {\n                        selRow = newRow;\n                        selCount = 1;\n                        again = false;\n                    }\n                }\n                else if (input == 's' || input == 'ы')\n                {\n                    byte newRow = selRow;\n                    \n                    for (byte i = 3; i > selRow; i--)\n                    {\n                        if (sticks[i]) newRow = i;\n                    }\n\n                    if (newRow !== selRow)\n                    {\n                        selRow = newRow;\n                        selCount = 1;\n                        again = false;\n                    }\n                }\n                else if (input == 'a' || input == 'ф')\n                {\n                    if (selCount < sticks[selRow])\n                        {\n                            selCount++;\n                            again = false;\n                        }\n                    }\n                else if (input == 'd' || input == 'в')\n                {\n                    if (selCount > 1)\n                    {\n                        selCount--;\n                        again = false;\n                    }\n                }\n                else if (input == ' ')\n                {\n                    sticks[selRow] -= selCount;\n                    move = 1;\n                    moveMade = true;\n                    isFirst = false;\n                    again = false;\n                    selCount = 0;\n                }\n                else if (input == 'q' || input == 'й')\n                {\n                    move = 4;\n                    gaveUp = true;\n                    selCount = 0;\n                    again = false;\n                }\n\n                if (again) in input;\n            }\n            while (again);\n        }\n        #################################\n        #             ХОД ИИ            #\n        #################################\n        else if (move == 1)\n        {\n            #   СОРТИРУЕМ ПОЛЕ   #\n            byte sorted[4], indexes[] = [0, 1, 2, 3];\n            byte row;\n\n            for (byte i = 0; i < 4; i++)\n            {\n                sorted[i] = sticks[i];\n            }\n\n            # сортировка, сохранение исходных индексов\n            for (byte i = 0; i < 4; i++) {\n                for (byte j = i + 1; j < 4; j++) {\n                    if (sorted[i] > sorted[j]) {\n                        byte temp = sorted[i];\n                        sorted[i] = sorted[j];\n                        sorted[j] = temp;\n                        \n                        temp = indexes[i];\n                        indexes[i] = indexes[j];\n                        indexes[j] = temp;\n                    }\n                    \n                }\n            }\n\n            # Спички есть во всех четырех кучках\n            if (sorted[0]) \n            {\n                # В sorted[0] всегда ноль, его не проверяем\n                # Если в первых двух единицы, а остальные не равны, уравниваем их\n                if (sorted[1] == 1 && sorted[2] != sorted[3])\n                {\n                    row = 3;\n                    selCount = sorted[3] - sorted[2];\n                }\n                # Пытаемся привести к проигрышному варианту(XOR чисел = 0):\n                # Приведение к (1, 2, 4, 7) (+)\n                else if (sorted[1] == 3 && sorted[2] == 4 && sorted[3] == 7)\n                {\n                    row = 1;\n                    selCount = 1;\n                }\n                else if (sorted[1] == 2 && sorted[2] == 5 && sorted[3] == 7)\n                {\n                    row = 2;\n                    selCount = 1;\n                }\n                # Приведение к (1, 3, 4, 6) (+)\n                else if (sorted[1] == 3 && sorted[2] == 5 && sorted[3] == 6)\n                {\n                    row = 2;\n                    selCount = 1;\n                }\n                # Приведение к (1, 2, 3) (+)\n                else if (sorted[1] == 2 && sorted[2] == 3)\n                {\n                    row = 3;\n                    selCount = sorted[3];\n                }\n                # Приведение к (1, 4, 5) (+)\n                else if (sorted[1] == 4 && sorted[2] == 5)\n                {\n                    row = 3;\n                    selCount = sorted[3];\n                }\n                else if (sorted[2] == 4 && sorted[3] == 5)\n                {\n                    row = 1;\n                    selCount = sorted[1];\n                }\n                # Приведение к (2, 4, 6) (+)\n                else if (sorted[1] == 2 && sorted[2] == 4 && sorted[3] == 6)\n                {\n                    row = 0;\n                    selCount = 1;\n                }\n                # Приведение к (2, 5, 7) (+)\n                else if (sorted[1] == 2 && sorted[2] == 5 && sorted[3] == 7)\n                {\n                    row = 0;\n                    selCount = 1;\n                }\n                # Приведение к (3, 4, 7) (+)\n                else if (sorted[1] == 3 && sorted[2] == 4 && sorted[3] == 7)\n                {\n                    row = 0;\n                    selCount = 1;\n                }\n                # Если нет выигрышной стратегии, тянем одну из последней (-)\n                else\n                {\n                    row = 3;\n                    selCount = 1;\n                }\n            }\n            # Спички есть только в трех кучках\n            else if (sorted[1])\n            {\n                # Если в двух кучках по одной спичке, уравниваем третью (+)\n                if (sorted[1] == 1 && sorted[2] == 1 && sorted[3] != 1)\n                {\n                    row = 3;\n                    selCount = sorted[3] - 1;\n                }\n                # Если есть две равные больше одного, то тянем все из третьей (+)\n                else if (sorted[1] == sorted[2])\n                {\n                    row = 3;\n                    selCount = sorted[3];\n                }\n                else if (sorted[2] == sorted[3])\n                {\n                    row = 1;\n                    selCount = sorted[1];\n                }\n                # Если все неравны, пытаемся привести к проигрышному варианту (XOR чисел = 0):\n                # Приведение к (1, 2, 3) (+)\n                else if (sorted[1] == 1 && sorted[2] == 2 && sorted[3] != 3)\n                {\n                    row = 3;\n                    selCount = sorted[3] - 3;\n                }\n                else if (sorted[1] == 1 && sorted[2] == 3)\n                {\n                    row = 3;\n                    selCount = sorted[3] - 2;\n                }\n                else if (sorted[1] == 2 && sorted[2] == 3)\n                {\n                    row = 3;\n                    selCount = sorted[3] - 1;\n                }\n                # Приведение к (1, 4, 5) (+)\n                else if (sorted[1] == 1 && sorted[2] == 4 && sorted[3] != 5)\n                {\n                    row = 3;\n                    selCount = sorted[3] - 5;\n                }\n                else if (sorted[1] == 1 && sorted[2] == 5)\n                {\n                    row = 3;\n                    selCount = sorted[3] - 4;\n                }\n                # Приведение к (2, 4, 6) (+)\n                else if (sorted[1] == 2 && sorted[2] == 4 && sorted[3] == 7)\n                {\n                    row = 3;\n                    selCount = 1;\n                }\n                # Приведение к (2, 5, 7) (+)\n                else if (sorted[1] > 2 && sorted[2] == 5 && sorted[3] == 7)\n                {\n                    row = 1;\n                    selCount = sorted[1] - 2;\n                }\n                # Приведение к (3, 4, 7) (+)\n                else if (sorted[1] == 3 && sorted[2] == 5 && sorted[3] == 7)\n                {\n                    row = 2;\n                    selCount = 1;\n                }\n                # Если нет выигрышной стратегии, тянем одну из последней\n                else\n                {\n                    row = 3;\n                    selCount = 1;\n                }\n            }\n            # Спички есть только в двух кучках\n            else if (sorted[2])\n            {\n                # Если в одной из кучек осталась одна спичка, забираем все из второй (+)\n                if (sorted[2] == 1)\n                {\n                    row = 3;\n                    selCount = sorted[3];\n                }\n                # Если в обоих больше 1 и они не равны, то уравниваем (+)\n                else if (sorted[2] != sorted[3])\n                {\n                    row = 3;\n                    selCount = sorted[3] - sorted[2];\n                }\n                # Если в обоих больше 1 и они равны, тянем одну из любой (-)\n                else\n                {\n                    row = 2;\n                    selCount = 1;\n                }\n            }\n            # Спички остались только в одной кучке\n            else\n            {\n                # Если в ней всего одна, то тянем ее (-)\n                if (sorted[3] == 1)\n                {\n                    row = 3;\n                    selCount = 1;\n                }\n                # Если больше одной, то оставляем одну (+)\n                else\n                {\n                    row = 3;\n                    selCount = sorted[3] - 1;\n                }\n            }\n\n            #   Восстанавливаем selRow из row   #\n            selRow = indexes[row];\n\n            isFirst = false;\n            move = 2;\n        }\n        #################################\n        #       ПРИМЕНЕНИЕ ХОДА ИИ      #\n        #################################\n        else if (move == 2)\n        {\n            sticks[selRow] -= selCount;\n            move = 0;\n            moveMade = true;\n\n            # Стартовый селект игрока\n            for (byte i = 3; i != 255; i--)\n            {\n                if (sticks[i])\n                {\n                    selRow = i;\n                    selCount = 1;\n                }\n            }\n        }\n        #################################\n        #           КОНЕЦ ИГРЫ          #\n        #################################\n        else if (move == 3)\n        {\n            win++;\n            roundCycle = false;\n        }\n        else if (move == 4)\n        {\n            loss++;\n            roundCycle = false;\n        }\n\n        #################################\n        #      ПРОВЕРКА КОНЦА ИГРЫ      #\n        #################################\n        if (moveMade)\n        {\n            moveMade = false;\n            if (sticks[0] == 0 && sticks[1] == 0 && sticks[2] == 0 && sticks[3] == 0)\n            {\n                if (move == 1) move = 4; # игрок проиграл\n                else           move = 3; # игрок выиграл\n\n                selCount = 0;\n            }\n        }\n    }\n}",
    "input": "",
    "language": "bb",
    "isSubtab": false
  }
]