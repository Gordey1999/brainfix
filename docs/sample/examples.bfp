    "code": "# @title: Умножение\n\n# Таблица умножения\n\nbyte i = 1;\n\nwhile (++i < 10) {\n    for (byte j = 2; j < 10; j++)\n        out i, ' * ', j, ' = ', i * j, eol;\n\n    out eol;\n}",
