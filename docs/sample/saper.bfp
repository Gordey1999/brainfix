  {
    "code": "# @title: Исходный код\n# @buffered_input: FALSE\n# @steps_per_frame: 50M\n\n# Это исходный код Сапера, написанный на BrainFix.\n# И его можно редактировать.\n# Чтобы собрать код в Brainfuck, используй кнопки BUILD или MIN.\n\n\nbyte seed;\nbyte size;\nbyte bombs;\nbyte intro = 18;\nbyte selected = 6;\n\n\nout '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\nout '------------------------------------------------------';\nout '\\n\\n\\n\\n\\n\\n\\n\\n';\nout '         Убедись, что обе полосы хорошо видны';\nout '\\n\\n\\n\\n\\n\\n\\n\\n';\nout '                Нажми любую клавишу\\n';\nout '------------------------------------------------------';\nin 'dummy';\n\nout '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\nout '    Итак... Приступим\\n';\nout '    Для начала нам нужен сид для рандомизации поля\\n';\nout '    Введи слово или число и нажми Enter\\n';\nout '\\n\\n\\n\\n\\n\\n> ';\nin seed;\n\nout '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\nout '    Отлично! Все готово!\\n';\nout '    Теперь нажми любую клавишу...';\nout '\\n\\n\\n\\n\\n\\n> ';\nin 'dummy';\n\n\nwhile (intro)\n{\n    ############################################\n    ##              Главное меню              ##\n    ############################################\n\n    while (intro)\n    {\n        out '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\n\n        if (intro == 1 && selected == 6) selected = 0;\n\n        for (byte i = 0; i < 17; i++)\n        {\n            byte slide;\n\n            if (intro > 12)\n            {\n                if (i % 6 >= 18 - intro) slide = 7;\n                else slide = ((49 - intro) - i + selected) % 6;\n            }\n            else slide = ((49 - intro) - i + selected) % 6;\n\n\n            if      (slide == 5) out '\\| ';\n            else if (slide == 4) out ' | ';\n            else if (slide == 3) out ' |\\';\n            else if (slide == 2) out ' |/';\n            else if (slide == 1) out ' / ';\n            else if (slide == 0) out '/| ';\n            else                 out '   ';\n\n            if      (i == intro - 1) out '      ___    ____  _____  _____  _____  __     ';\n            else if (i == intro + 0) out '     /   \\  /    ||     ||   __||     ||  |    ';\n            else if (i == intro + 1) out '    |  |__||  |  ||  |  ||  |_  |  |  ||  |    ';\n            else if (i == intro + 2) out '    |  |__ |     ||  |  ||   _| |   __||__|    ';\n            else if (i == intro + 3) out '    |  |  ||  |  ||  |  ||  |__ |  |    __     ';\n            else if (i == intro + 4) out '     \\___/ |__|__||__|__||_____||__|   |__|    ';\n\n            else if (i == intro + 8)\n                if (selected == 0)   out '                  > Просто <                   ';\n                else                 out '                    Просто                     ';\n            else if (i == intro + 9)\n                if (selected == 1)   out '                  > Средне <                   ';\n                else                 out '                    Средне                     ';\n            else if (i == intro + 10)\n                if (selected == 2)   out '                  > Сложно <                   ';\n                else                 out '                    Сложно                     ';\n\n            else if (i == intro + 15)out '        W/S - перемещение, Space - выбор       ';\n            else if (i == intro - 8)\n                if (intro == 18)     out ' И еще одну...                                 ';\n                else                 out ' Продолжай нажимать...                         ';\n\n            else                     out '                                               ';\n\n            if      (slide == 5) out ' |/';\n            else if (slide == 4) out ' /';\n            else if (slide == 3) out '/|';\n            else if (slide == 2) out '\\|';\n            else if (slide == 1) out ' |';\n            else if (slide == 0) out ' |\\';\n\n            out eol;\n        }\n        out '> ';\n\n        if (intro == 1)\n        {\n            char input;\n            bool again = true;\n\n            while (again)\n            {\n                again = false;\n                in input;\n\n                if      ((input == 'w' || input == 'ц') && selected > 0) selected--;\n                else if ((input == 's' || input == 'ы') && selected < 2) selected++;\n                else if (input == ' ')\n                {\n                    if (selected == 0)\n                    {\n                        size = 8;\n                        bombs = 8;\n                    }\n                    else if (selected == 1)\n                    {\n                        size = 12;\n                        bombs = 16;\n                    }\n                    else if (selected == 2)\n                    {\n                        size = 16;\n                        bombs = 32;\n                    }\n                    intro--;\n                }\n                else again = true;\n            }\n\n            intro++;\n        }\n        else in 'dummy';\n\n        intro--;\n    }\n\n\n    ############################################\n    ##             Генерация поля             ##\n    ############################################\n\n    # Обозначения на карте:\n    # 0-8        - цифры (в тумане)\n    # 'B'        - бомба (в тумане)\n    # '0' - '8'  - цифры (открыто)\n    # 'Ф'        - Флаг с бомбой\n    # 200-208    - Флаг с цифоркой\n    char map[16][16] = 0;\n    byte x = 0, y = 0;\n    bool loop = true, win = false;\n    byte rightFlags = 0, wrongFlags = 0;\n\n    # ***   Закладываем бомбы    *** #\n    for (byte i = 0; i < bombs; i++)\n    {\n        byte n, m;\n\n        do\n        {\n            seed = 137 * seed + 1;\n            n = (seed + (seed / size)) % size;\n            seed = 137 * seed + 1;\n            m = (seed + (seed / size)) % size;\n            seed++;\n\n        } while (map[n][m]);\n\n        map[n][m] = 'B';\n    }\n\n    # ***   Расставляем цифорки    *** #\n    for (byte i = 0; i < size; i++)\n    {\n        for (byte j = 0; j < size; j++)\n        {\n            if (map[i][j] == 'B')\n            {\n                byte fromI = i, toI = i, fromJ = j, toJ = j;\n\n                if (i > 0)        fromI--;\n                if (j > 0)        fromJ--;\n                if (i < size - 1) toI++;\n                if (j < size - 1) toJ++;\n\n                for (byte n = fromI; n <= toI; n++)\n                {\n                    for (byte m = fromJ; m <= toJ; m++)\n                    {\n                        if (map[n][m] != 'B')\n                        {\n                            map[n][m]++;\n                        }\n                    }\n                }\n            }\n        }\n    }\n\n    ############################################\n    ##              Игровой цикл              ##\n    ############################################\n    while (loop)\n    {\n        # ***   Отрисовка    *** #\n        out '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\n\n        for (byte i = 0; i < size; i++)\n        {\n            for (byte j = 0; j < size; j++)\n            {\n                if (i == y && j == x) out '>';\n                else out ' ';\n\n                char cell = map[i][j]; # map[0][index];\n                char cellTmp = cell - 200;\n\n                if      (cell == 'B') out '.';\n                else if (cell == '0') out ' ';\n                else if (cell < 9)    out '.';\n                else if (cellTmp < 9)  out 'Ф';\n                else                  out cell;\n            }\n\n            if      (i == 0)        out '   Бомбы: ', bombs;\n            else if (i == 1)        out '   Флаги: ', rightFlags + wrongFlags;\n            else if (i == size - 3) out '   WASD  - перемещение';\n            else if (i == size - 2) out '   Space - открыть';\n            else if (i == size - 1) out '   F     - флаг';\n\n            out eol;\n        }\n\n        out '\\n> ';\n\n\n        # ***   Обработка ввода    *** #\n        char input;\n        bool again = true;\n\n        while (again)\n        {\n            again = false;\n            in input;\n\n            if      ((input == 'w' || input == 'ц') && y > 0)        y--;\n            else if ((input == 's' || input == 'ы') && y < size - 1) y++;\n            else if ((input == 'a' || input == 'ф') && x > 0)        x--;\n            else if ((input == 'd' || input == 'в') && x < size - 1) x++;\n            else if ((input == 'f' || input == 'а'))\n            {\n                char cell = map[y][x];\n\n                if      (cell == 'B') map[y][x] = 'Ф';\n                else if (cell == 'Ф') map[y][x] = 'B';\n                else if (cell < 9)    map[y][x] += 200;\n                else if (cell > 199)  map[y][x] -= 200;\n                else again = true;\n\n\n                # ***   Считаем флаги   *** #\n                rightFlags = 0;\n                wrongFlags = 0;\n                for (byte i = 0; i < size; i++)\n                {\n                    for (byte j = 0; j < size; j++)\n                    {\n                        if      (map[i][j] == 'Ф') rightFlags++;\n                        else if (map[i][j] > 199)  wrongFlags++;\n                    }\n                }\n\n                if (wrongFlags == 0 && rightFlags == bombs)\n                {\n                    win = true;\n                    loop = false;\n                }\n            }\n            else if (input == ' ')\n            {\n                bool emptyFound = false;\n\n                if (map[y][x] == 'B')\n                {\n                    loop = false;\n                }\n                else if (map[y][x] == 0)\n                {\n                    map[y][x] = '0';\n                    emptyFound = true;\n                }\n                else if (map[y][x] < 9)\n                {\n                    map[y][x] += '0';\n                }\n                else again = true;\n\n                # ***   Открытие ячеек   *** #\n                while (emptyFound)\n                {\n                    emptyFound = false;\n                    for (byte i = 0; i < size; i++)\n                    {\n                        for (byte j = 0; j < size; j++)\n                        {\n                            if (map[i][j] == '0')\n                            {\n                                byte fromI = i, toI = i, fromJ = j, toJ = j;\n\n                                if (i > 0)        fromI--;\n                                if (j > 0)        fromJ--;\n                                if (i < size - 1) toI++;\n                                if (j < size - 1) toJ++;\n\n                                for (byte n = fromI; n <= toI; n++)\n                                {\n                                    for (byte m = fromJ; m <= toJ; m++)\n                                    {\n                                        char cell = map[n][m];\n\n                                        if      (cell < 9)   map[n][m] += '0';\n                                        else if (cell > 199) map[n][m] -= 152;\n\n                                        if (cell == 0 || cell == 200) emptyFound = true;\n                                    }\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n            else again = true;\n\n\n        }\n    }\n\n    ############################################\n    ##               Конец игры               ##\n    ############################################\n    out '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\n\n    for (byte i = 0; i < size; i++)\n    {\n        for (byte j = 0; j < size; j++)\n        {\n            if (i == y && j == x) out '>';\n            else out ' ';\n\n            char cell = map[i][j];\n\n            if (cell == 'B' || cell == 'Ф')\n            {\n                if (win) out 'Ф';\n                else     out '*';\n            }\n            else         out ' ';\n        }\n\n        if (win)\n        {\n            if (i == 0)\n                out '   ПОБЕДА!';\n            else if (i == 1)\n            {\n                if (selected == 0)\n                    out '   Новичкам везет...';\n                else if (selected == 1)\n                    out '   Неплохо';\n                else\n                    out '   Л Е Г Е Н Д А';\n            }\n\n        }\n        else\n        {\n            if (i == 0)\n                out '   БА-БАХ!!!';\n            else if (i == 1)\n            {\n                if (rightFlags == 0 && wrongFlags == 0)\n                    out '   Это было... Быстро';\n                else if (rightFlags + 4 > bombs)\n                    out '   Почти, но нет)';\n                else if (selected == 0)\n                    out '   Может выберешь уровень попроще?)';\n                else\n                    out '   Ты проиграл';\n            }\n        }\n\n        if (i == size - 1)\n        {\n            out     '   Нажми любую кнопку';\n        }\n\n        out eol;\n    }\n\n    out '\\n> ';\n    in 'dummy';\n\n    intro++;\n}\n",
    "input": "",
    "language": "bb",
    "isSubtab": false
  }
]