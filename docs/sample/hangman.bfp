     }\n        else\n        {\n            out 'Отгадано слов: ', wonCount, ' из ', roundCount;\n        }\n        out eol;\n        \n        if (lives == 7) out '    ';\n        else            out '|   ';\n        if (lives > 1)  out '   ';\n        else            out '/  ';\n        if (lives)      out '  ';\n        else            out ' \\';\n        out eol;\n\n        if (lives == 7) out '             ';\n        else            out '|            ';\n        if (lives == 0 || won) out 'Enter - продолжить';\n        else if (status == 0)  out 'Введи букву и нажми Enter';\n        else if (status == 1)  out 'Введена не буква!';\n        else if (status == 2)  out 'Неверная раскладка!';\n        else if (status == 3)  out 'Буква ', letter, ' уже была!';\n        else if (status == 4)  out 'Буквы ', letter, ' в слове нет!';\n        else                   out 'Буква ', letter, ' в слове есть!';\n        \n        out '\\n\\n> ';\n        \n\n        #################################\n        #        ОБРАБОТКА ВВОДА        #\n        #################################\n        char input;\n        in input;\n        letter = input;\n        while (input != '\\n')\n        {\n            in input;\n        }\n\n        if (letter >= 'а' && letter <= 'я') letter -= ('а' - 'А');\n        if (letter >= 'a' && letter <= 'z') letter -= ('a' - 'A');\n\n        if (won || lives == 0)\n        {\n            # При завершении раунда выходим из цикла\n            round = false;\n            status = 0;\n        }\n        else if (letter >= 'А' && letter <= 'Я')\n        {\n            # Если буквы еще не было\n            if (letters[letter - 'А'])\n            {\n                bool found = false;\n                \n                # Проверяем слово\n                for (byte i = 0; i < sizeof word; i++)\n                {\n                    if (letter + 32 == word[i])\n                    {\n                        found = true;\n                        wordPrint[i] = letter;\n                    }\n                }\n\n                if (found)\n                {\n                    status = 5;\n                }\n                else\n                {\n                    status = 4;\n                    lives--;\n                }\n                \n                letters[letter - 'А'] = false;\n\n                # Обновляем сид, чтобы слова не повторялись\n                seed = 137 * seed + 1;\n            }\n            else\n            {\n                status = 3; # уже была\n            }\n        }\n        else if (letter >= 'A' && letter <= 'Z')\n        {\n            status = 2; # неверная раскладка\n        }\n        else\n        {\n            status = 1; # введена не буква\n        }\n        \n\n        #################################\n        #          КОНЕЦ ИГРЫ           #\n        #################################\n        \n        # Если попытки закончились, открываем слово\n        if (lives == 0)\n        {\n            for (byte i = 0; i < sizeof word; i++)\n            {\n                if (word[i])\n                {\n                    wordPrint[i] = word[i] - 32;\n                }\n            }\n        }\n        # Если введена верная буква, отгадано ли все слово\n        else if (status == 5)\n        {\n            won = true;\n            for (byte i = 0; i < sizeof word; i++)\n            {\n                if (word[i] && wordPrint[i] == '_')\n                {\n                    won = false;\n                }\n            }\n            if (won)\n            {\n                wonCount++;\n            }\n        }\n        \n    }\n}",
