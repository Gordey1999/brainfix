    "code": "# @title: Исходный код\n\n# Это исходный код Виселицы, написанный на BrainFix.\n# И его можно редактировать.\n# Чтобы собрать код в Brainfuck, используй кнопки BUILD или MIN.\n# Но процесс сборки не быстрый.\n\n\n# Темы:\n# 0 - Еда\n# 1 - Животные\n# 2 - Профессии\n# 3 - Техника\nbyte seed, topic;\nbool play = true;\nbool randomTopic = false;\n\n\nout '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\nout 'Для старта нам нужен сид\\n';\nout 'для генерации случайных чисел.\\n';\nout '\\n';\nout 'Введи любое слово или число\\n';\nout 'и нажми Enter.\\n';\nout '\\n> ';\nin seed;\n\n\n\n\nwhile (topic < '1' || topic > '5')\n{\n    out '\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n\\n';\n    out '------------   ВИСЕЛИЦА   ------------\\n';\n    out '_______                       by Gordy\\n';\n    out '|     |    Выбери категорию:\\n';\n    out '|     |\\n';\n    out '|    / \\   1. Еда\\n';\n    out '|    \\_/   2. Животные\\n';\n    out '|          3. Профессии\\n';\n    out '|          4. Техника\\n';\n    out '|          5. Случайная\\n';\n    out '|\\n';\n    out '|  Введи номер категории и нажми Enter\\n';\n    out '\\n> ';\n\n    char input;\n    in input;\n    topic = input;\n    while (input != '\\n')\n    {\n        in input;\n    }\n}\n\ntopic -= '1';\nif (topic == 4) randomTopic = true;\n\n\nbyte wonCount = 0, roundCount = 0;\n\n\nwhile (play)\n{\n    #################################\n    #         НАЧАЛО РАУНДА         #\n    #################################\n\n    char word[11], wordPrint[11] = 0;\n    bool letters[32] = true;  # Доступные буквы\n    byte lives = 7; # жизни: виселица, голова, тело, рука, рука, нога, нога\n    bool won = false;\n    char letter; # введенная буква\n\n    # Статусы ввода\n    # 0 - Начало раунда\n    # 1 - Введена не буква\n    # 2 - Неверная раскладка\n    # 3 - Буква уже вводилась ранее\n    # 4 - Такой буквы в слове нет\n    # 5 - Буква есть в слове\n    byte status = 0;\n\n    # Если случайная категория, меняем каждую игру\n    if (randomTopic)\n    {\n        seed = 137 * seed + 1;\n        topic = seed / 64;\n    }\n\n    # Перемешиваем сид\n    seed = 137 * seed + 1;\n    byte key = seed / 2;\n\n\n    #################################\n    #         ВЫБИРАЕМ СЛОВО        #\n    #################################\n    if (topic == 0)\n    {\n        if (key == 0)   word = 'песто';\n        if (key == 1)   word = 'баранка';\n        if (key == 2)   word = 'котлета';\n        if (key == 3)   word = 'киви';\n        if (key == 4)   word = 'ряженка';\n        if (key == 5)   word = 'подливка';\n        if (key == 6)   word = 'десерт';\n        if (key == 7)   word = 'какао';\n        if (key == 8)   word = 'компот';\n        if (key == 9)   word = 'кукуруза';\n        if (key == 10)  word = 'сосиска';\n        if (key == 11)  word = 'йогурт';\n        if (key == 12)  word = 'лимон';\n        if (key == 13)  word = 'томат';\n        if (key == 14)  word = 'сливки';\n        if (key == 15)  word = 'булочка';\n        if (key == 16)  word = 'гамбургер';\n        if (key == 17)  word = 'майонез';\n        if (key == 18)  word = 'маринад';\n        if (key == 19)  word = 'пломбир';\n        if (key == 20)  word = 'мармелад';\n        if (key == 21)  word = 'спаржа';\n        if (key == 22)  word = 'колбаса';\n        if (key == 23)  word = 'авокадо';\n        if (key == 24)  word = 'картофель';\n        if (key == 25)  word = 'каша';\n        if (key == 26)  word = 'кетчуп';\n        if (key == 27)  word = 'тыква';\n        if (key == 28)  word = 'грейпфрут';\n        if (key == 29)  word = 'арбуз';\n        if (key == 30)  word = 'брокколи';\n        if (key == 31)  word = 'кофе';\n        if (key == 32)  word = 'инжир';\n        if (key == 33)  word = 'банан';\n        if (key == 34)  word = 'креветка';\n        if (key == 35)  word = 'уксус';\n        if (key == 36)  word = 'кекс';\n        if (key == 37)  word = 'карбонара';\n        if (key == 38)  word = 'ананас'